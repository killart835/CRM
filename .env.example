# Скопируйте этот файл в .env и заполните значения
# На Railway эти же переменные добавляются в Variables

# Токен бота от @BotFather
TELEGRAM_TOKEN=1234567890:ABCdef...

# API ключ Groq (бесплатно на console.groq.com)
GROQ_API_KEY=gsk_...

# Ваш личный Telegram ID (узнать у @userinfobot)
MANAGER_CHAT_ID=123456789

# Модель Groq (можно менять)
GROQ_MODEL=llama-3.3-70b-versatile

# Системный промпт (необязательно, есть дефолтный)
# SYSTEM_PROMPT=Ты менеджер магазина...
